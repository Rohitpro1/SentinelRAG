# Unit 2.15 -- environment template for docker-compose.
#
# Copy to .env before running `docker compose up`. Every value here
# corresponds to a field on one of the app's domain Settings classes
# (app/core/settings/*.py) via that class's env_prefix -- nothing is
# hardcoded in docker-compose.yml itself beyond service hostnames, which
# come from Docker Compose's internal DNS (the service name IS the
# hostname; this is the correct externalized pattern for a compose
# network, not a hardcoded address -- "localhost" would be WRONG here
# since containers don't share a loopback interface).

# --- Ports exposed on the host (change if you have local conflicts) ---
BACKEND_PORT=8000
QDRANT_PORT=6333
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# --- Postgres container credentials ---
POSTGRES_USER=sentinelrag
POSTGRES_PASSWORD=sentinelrag
POSTGRES_DB=sentinelrag

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=admin

# --- StorageSettings (app/core/settings/storage.py) ---
# Service names below (qdrant/postgres/redis) resolve via Docker
# Compose's internal network -- correct for backend-to-infra traffic.
STORAGE__QDRANT_URL=http://qdrant:6333
STORAGE__POSTGRES_DSN=postgresql+asyncpg://sentinelrag:sentinelrag@postgres:5432/sentinelrag
STORAGE__REDIS_URL=redis://redis:6379/0

# --- EmbeddingSettings / RerankingSettings / NLISettings ---
# Real-provider credentials, if/when the backend is wired to use them
# (see UNIT_2_15.md's "known scope boundary" note -- not done by default
# in this unit). Leave blank to keep the backend on its default
# deterministic wiring (Unit 2.14).
EMBEDDING__API_KEY=
RERANKING__API_KEY=
NLI__API_KEY=
