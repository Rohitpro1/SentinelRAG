# SentinelRAG Environment Configuration Template

# --- AI Provider Configuration (app/core/settings/ai_provider.py) ---
# Supported values: gemini, deterministic
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Managed Cloud / Local Infrastructure Settings (app/core/settings/storage.py) ---
# Qdrant Cloud or Local Qdrant
STORAGE__QDRANT_URL=https://xxxxxx.cloud.qdrant.io:6333
STORAGE__QDRANT_API_KEY=your_qdrant_cloud_api_key_here
STORAGE__QDRANT_COLLECTION=sentinelrag_chunks

# Neon Managed PostgreSQL DSN (SSL required)
STORAGE__POSTGRES_DSN=postgresql+asyncpg://user:password@ep-xyz.neon.tech/sentinelrag?sslmode=require

# Upstash Managed Redis URL (TLS/SSL enabled via rediss://)
STORAGE__REDIS_URL=rediss://default:password@xyz.upstash.io:6379

# --- Port Declarations (Local / Docker Compose) ---
BACKEND_PORT=8000
QDRANT_PORT=6333
POSTGRES_PORT=5432
REDIS_PORT=6379
